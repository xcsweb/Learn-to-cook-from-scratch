        { "id": "cooking-oil", "name": "食用油", "amount": 30, "unit": "毫升", "type": "seasoning" }
      ],
      "steps": [
        {
          "order": 1,
          "title": "准备食材",
          "description": "番茄洗净，顶部划十字刀，用开水烫1分钟后去皮，切成小块。鸡蛋打入碗中，加少许盐，用筷子打散。葱切成葱花。",
          "image": "/images/recipes/tomato-eggs/step1.jpg",
          "tips": "番茄去皮后口感更好，不去皮也可以。打蛋时加少许盐可以让蛋更嫩滑。",
          "time": 5
        },
        {
          "order": 2,
          "title": "炒鸡蛋",
          "description": "锅烧热，倒入一半油，油温六成热时倒入蛋液。用筷子快速搅动，蛋液凝固成块后盛出备用。",
          "image": "/images/recipes/tomato-eggs/step2.jpg",
          "tips": "油温要够高，蛋液下锅后能迅速膨胀。不要炒太老，嫩一点更好吃。",
          "time": 2
        },
        {
          "order": 3,
          "title": "炒番茄",
          "description": "锅中再加少许油，放入葱花爆香。倒入番茄块，中火翻炒，用铲子压一压，让番茄出汁。",
          "image": "/images/recipes/tomato-eggs/step3.jpg",
          "tips": "番茄要炒出汁，这样汤汁更浓郁。可以加少许水帮助出汁。",
          "time": 3
        },
        {
          "order": 4,
          "title": "调味出锅",
          "description": "番茄出汁后，加入盐和糖调味。倒入炒好的鸡蛋，快速翻炒均匀，让鸡蛋裹上番茄汁。撒上葱花，出锅装盘。",
          "image": "/images/recipes/tomato-eggs/step4.jpg",
          "tips": "糖能提鲜，让番茄的酸甜味更突出。不要炒太久，保持鸡蛋的嫩滑。",
          "time": 2
        }
      ],
      "tips": [
        "番茄要选熟一点的，更容易出汁",
        "鸡蛋不要炒太老，嫩滑才好吃",
        "糖的用量根据番茄酸甜度调整"
      ],
      "commonMistakes": [
